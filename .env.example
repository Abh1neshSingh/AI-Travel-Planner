# AI Travel Planner Environment Variables
# Copy this file to .env and fill in your API keys

# Mistral AI API Key (required for travel planning)
# Get your key at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: OpenAI API Key (alternative to Mistral)
# Get your key at: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: Google Maps API Key (for enhanced map features)
# Get your key at: https://developers.google.com/maps
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here